# Lyclaw Environment Variables

# OpenClaw Gateway Configuration
OPENCLAW_GATEWAY_PORT=18789

# Development Configuration
VITE_DEV_SERVER_PORT=5173

# Optional startup device access gate.
# The app calls this endpoint before showing setup/login/workspace.
# Expected POST body: { "token": "...", "os_type": "windows" | "mac" }.
# Expected response: { "success": true, "exists": true }.
CLAWX_DEVICE_ACCESS_URL=https://lyclawtoken.lingyiitech.com/api/check-token
# Optional: override the built-in Authorization value for local tests.
CLAWX_DEVICE_ACCESS_AUTH_TOKEN=
# Optional: override the bundled GetDeviceGUID.exe path for local tests.
CLAWX_DEVICE_GUID_EXE_PATH=
# Optional: override the Windows helper token or macOS serial number for local tests.
CLAWX_DEVICE_ACCESS_DEVICE_TOKEN=
# Optional: override os_type for local tests. Supported values: windows, mac.
CLAWX_DEVICE_ACCESS_OS_TYPE=
# Disabled by default. Set a positive value only for local tests.
CLAWX_DEVICE_ACCESS_CACHE_TTL_MS=0
CLAWX_DEVICE_ACCESS_FAIL_OPEN=0

# Release Configuration (CI/CD)
# Apple Developer Credentials
APPLE_ID=your@email.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX

# Code Signing Certificate
CSC_LINK=path/to/certificate.p12
CSC_KEY_PASSWORD=certificate_password

# GitHub Token for releases
GH_TOKEN=github_personal_access_token
